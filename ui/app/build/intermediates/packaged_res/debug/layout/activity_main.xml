<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dashboard"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Tài khoản: "
            android:textColor="#444444" />

        <TextView
            android:id="@+id/tvRole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Vai trò: "
            android:textColor="#444444" />

        <LinearLayout
            android:id="@+id/landlordOverviewSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:background="#F7F7F7"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvOverviewTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tổng quan chủ trọ"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvOverviewRevenue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Doanh thu tháng này: ..."
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvOverviewRooms"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Phòng: 0" />

                <TextView
                    android:id="@+id/tvOverviewPaid"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Đã thanh toán: 0" />

                <TextView
                    android:id="@+id/tvOverviewOverdue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Trễ hạn: 0" />
            </LinearLayout>

            <Button
                android:id="@+id/btnOverviewReports"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Xem báo cáo chi tiết" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Hoạt động gần đây"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentActivities"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/tvRecentEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Chưa có hoạt động gần đây"
                android:textColor="#777777"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tenantSummarySection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvTenantSummaryTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Thông tin nhanh"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTenantScope"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Quyền tenant: xem profile, phòng, hợp đồng, sự cố, billing, khách ra vào."
                android:textColor="#666666" />

            <TextView
                android:id="@+id/tvLandlordInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Chủ trọ: N/A" />

            <TextView
                android:id="@+id/tvContractInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Hợp đồng: N/A" />

            <TextView
                android:id="@+id/tvRoomInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Phòng: N/A" />

            <TextView
                android:id="@+id/tvBuildingInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Tòa nhà: N/A" />
        </LinearLayout>

        <Button
            android:id="@+id/btnProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Profile cá nhân" />

        <Button
            android:id="@+id/btnRooms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Quản Lý Phòng" />

        <Button
            android:id="@+id/btnBuildings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Quản Lý Tòa Nhà" />

        <Button
            android:id="@+id/btnTenants"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Quản Lý Người Thuê" />

        <Button
            android:id="@+id/btnIncidents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Quản Lý Sự Cố" />

        <Button
            android:id="@+id/btnContracts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Hợp Đồng" />

        <Button
            android:id="@+id/btnBilling"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Hóa Đơn / Billing" />

        <Button
            android:id="@+id/btnReports"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Báo cáo thống kê"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnGuestEntries"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Khai báo khách ra vào" />

        <LinearLayout
            android:id="@+id/layoutOtherFunctions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvOtherFunctionsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Chức năng khác"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnCreateTenantAccount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tạo tài khoản khách thuê" />
        </LinearLayout>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#d32f2f"
            android:text="Đăng xuất" />

    </LinearLayout>
</ScrollView>
