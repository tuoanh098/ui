<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/etTenantName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Họ tên *" />

        <EditText
            android:id="@+id/etTenantCccd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="CCCD *" />

        <EditText
            android:id="@+id/etTenantPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="SĐT"
            android:inputType="phone" />

        <EditText
            android:id="@+id/etTenantBirth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Ngày sinh (dd-MM-yyyy)" />

        <EditText
            android:id="@+id/etTenantGender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Giới tính" />

        <EditText
            android:id="@+id/etTenantAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Địa chỉ" />

        <AutoCompleteTextView
            android:id="@+id/etTenantRoomId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Chọn phòng (tìm theo mã phòng)" />

        <AutoCompleteTextView
            android:id="@+id/etTenantAccountId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Chọn tài khoản (username/họ tên)" />
    </LinearLayout>
</ScrollView>
