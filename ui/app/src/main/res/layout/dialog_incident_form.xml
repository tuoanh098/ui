<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/etIncidentLoai"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Loại sự cố *" />

        <EditText
            android:id="@+id/etIncidentMoTa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Mô tả"
            android:minLines="2" />

        <AutoCompleteTextView
            android:id="@+id/etIncidentToaId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Chọn tòa nhà (optional)" />

        <AutoCompleteTextView
            android:id="@+id/etIncidentPhongId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Chọn phòng *" />

        <AutoCompleteTextView
            android:id="@+id/etIncidentReportedBy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Chọn người báo *" />

        <EditText
            android:id="@+id/etIncidentStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Trạng thái (PENDING / IN_PROGRESS / DONE)" />
    </LinearLayout>
</ScrollView>
