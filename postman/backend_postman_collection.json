{
  "info": {
        "name": "Trohub Backend - Postman Collection (Grouped)",
        "_postman_id": "trohub-backend-postman",
        "description": "Grouped Postman collection with folders per resource and basic assertions. Set the environment variable `baseUrl` (default http://localhost:8081).",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
      },
      "variable": [
        { "key": "baseUrl", "value": "http://localhost:8081" },
        { "key": "accessToken", "value": "" },
        { "key": "incidentId", "value": "" },
        { "key": "invoiceId", "value": "" },
        { "key": "tenantId", "value": "" },
        { "key": "phongId", "value": "" }
      ],
          "auth": {
            "type": "bearer",
            "bearer": [
              {
                "key": "token",
                "value": "{{accessToken}}",
                "type": "string"
              }
            ]
          },
      "item": [
        {
          "name": "Auth",
          "item": [
            {
              "name": "Login",
              "request": {
                "method": "POST",
                "header": [ { "key": "Content-Type", "value": "application/json" } ],
                "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@123\"\n}" },
                "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
              },
              "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Login returns 200', function () { pm.response.to.have.status(200); });", "try { var json = pm.response.json(); if (json && json.accessToken) { pm.environment.set('accessToken', json.accessToken); if (json.user && json.user.id) pm.environment.set('currentUserId', json.user.id); } } catch (e) {}" ] } } ]
            },
            {
              "name": "Register",
              "request": {
                "method": "POST",
                "header": [ { "key": "Content-Type", "value": "application/json" } ],
                "body": { "mode": "raw", "raw": "{\n  \"username\": \"user1\",\n  \"password\": \"User@1234\",\n  \"email\": \"user1@example.com\"\n}" },
                "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
              },
              "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Register returns 200', function () { pm.response.to.have.status(200); });", "try { var json = pm.response.json(); if (json && json.id) pm.environment.set('currentUserId', json.id); } catch (e) {}" ] } } ]
            }
          ]
        },
        {
          "name": "Phongs",
          "item": [
            {
              "name": "List Phongs",
              "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/phongs", "host": ["{{baseUrl}}"], "path": ["api","phongs"] } },
              "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('GET Phongs returns 200', function () { pm.response.to.have.status(200); });" ] } } ]
            },
            {
              "name": "Create Phong",
              "request": {
                "method": "POST",
                "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" } ],
                "body": { "mode": "raw", "raw": "{\n  \"soPhong\": \"P-101\",\n  \"moTa\": \"Phòng tầng 1\",\n  \"soLuong\": 1,\n  \"giaThue\": 1500000\n}" },
                "url": { "raw": "{{baseUrl}}/api/phongs", "host": ["{{baseUrl}}"], "path": ["api","phongs"] }
              },
              "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Create Phong returns 201', function () { pm.response.to.have.status(201); });", "try { var json = pm.response.json(); if (json && json.id) pm.environment.set('phongId', json.id); } catch (e) {}" ] } } ]
            },
            {
              "name": "Update Phong",
              "request": { "method": "PUT", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"soPhong\": \"P-101\",\n  \"moTa\": \"Phòng cập nhật\",\n  \"soLuong\": 2,\n  \"giaThue\": 1600000\n}" }, "url": { "raw": "{{baseUrl}}/api/phongs/{{phongId}}", "host": ["{{baseUrl}}"], "path": ["api","phongs","{{phongId}}"] } },
              "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Update Phong returns 200', function () { pm.response.to.have.status(200); });" ] } } ]
            },
            {
              "name": "Delete Phong",
              "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/phongs/{{phongId}}", "host": ["{{baseUrl}}"], "path": ["api","phongs","{{phongId}}"] } },
              "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Delete Phong returns 204', function () { pm.response.to.have.status(204); });" ] } } ]
            }
          ]
        },
        {
          "name": "Tenants",
          "item": [
            { "name": "List Tenants", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/tenants", "host": ["{{baseUrl}}"], "path": ["api","tenants"] } }, "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('List tenants returns 200', function () { pm.response.to.have.status(200); });" ] } } ] },
            { "name": "Create Tenant", "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"hoTen\": \"Tran Van B\",\n  \"email\": \"tranb@example.com\",\n  \"sdt\": \"0987654321\",\n  \"phongId\": {{phongId}}\n}" }, "url": { "raw": "{{baseUrl}}/api/tenants", "host": ["{{baseUrl}}"], "path": ["api","tenants"] } }, "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Create tenant returns 201', function () { pm.response.to.have.status(201); });", "try { var json = pm.response.json(); if (json && json.id) pm.environment.set('tenantId', json.id); } catch (e) {}" ] } } ] },
            { "name": "Get Tenant", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/tenants/{{tenantId}}", "host": ["{{baseUrl}}"], "path": ["api","tenants","{{tenantId}}"] } }, "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Get tenant returns 200', function () { pm.response.to.have.status(200); });" ] } } ] },
            { "name": "Update Tenant", "request": { "method": "PUT", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"hoTen\": \"Tran Van B Updated\",\n  \"email\": \"tranb+u@example.com\",\n  \"sdt\": \"0987654321\"\n}" }, "url": { "raw": "{{baseUrl}}/api/tenants/{{tenantId}}", "host": ["{{baseUrl}}"], "path": ["api","tenants","{{tenantId}}"] } }, "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Update tenant returns 200', function () { pm.response.to.have.status(200); });" ] } } ] },
            { "name": "Delete Tenant", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/tenants/{{tenantId}}", "host": ["{{baseUrl}}"], "path": ["api","tenants","{{tenantId}}"] } }, "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Delete tenant returns 204', function () { pm.response.to.have.status(204); });" ] } } ] }
          ]
        },
        {
          "name": "Incidents",
          "item": [
            { "name": "Create Incident", "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"tieuDe\": \"Rò nước phòng P-101\",\n  \"moTa\": \"Nước rỉ từ trần\",\n  \"ngayXayRa\": \"2026-04-20T10:00:00\",\n  \"phongId\": 1,\n  \"nguoiBao\": \"Le Thi A\",\n  \"trangThai\": \"OPEN\"\n}" }, "url": { "raw": "{{baseUrl}}/api/incidents", "host": ["{{baseUrl}}"], "path": ["api","incidents"] } }, "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Create Incident returns 201', function () { pm.response.to.have.status(201); });", "try { var json = pm.response.json(); if (json && json.id) pm.environment.set('incidentId', json.id); } catch (e) {}" ] } } ] },
            { "name": "Get Incident", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/incidents/{{incidentId}}", "host": ["{{baseUrl}}"], "path": ["api","incidents","{{incidentId}}"] } }, "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Get incident by id returns 200', function () { pm.response.to.have.status(200); });" ] } } ] },
            { "name": "Upload Attachment", "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "body": { "mode": "formdata", "formdata": [ { "key": "file", "type": "file", "src": "", "description": "Allowed types: image/png,image/jpeg,image/jpg,image/gif,application/pdf (max 5 MB)" } ] }, "url": { "raw": "{{baseUrl}}/api/incidents/{{incidentId}}/attachments", "host": ["{{baseUrl}}"], "path": ["api","incidents","{{incidentId}}","attachments"] } }, "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Upload returns 200 or 201', function () { pm.expect(pm.response.code).to.be.oneOf([200,201]); });" ] } } ] },
            { "name": "Upload Oversize Test", "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "body": { "mode": "formdata", "formdata": [ { "key": "file", "type": "file", "src": "", "description": "Use a file >5MB to test oversize validation — expected response: 400" } ] }, "url": { "raw": "{{baseUrl}}/api/incidents/{{incidentId}}/attachments", "host": ["{{baseUrl}}"], "path": ["api","incidents","{{incidentId}}","attachments"] } }, "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Oversize upload should return 400', function () { pm.response.to.have.status(400); });" ] } } ] },
            { "name": "List Incidents", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/incidents", "host": ["{{baseUrl}}"], "path": ["api","incidents"] } }, "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('List incidents returns 200', function () { pm.response.to.have.status(200); });" ] } } ] },
            { "name": "Update Incident", "request": { "method": "PUT", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"tieuDe\": \"Rò nước - cập nhật\",\n  \"moTa\": \"Đã sửa tạm\",\n  \"phongId\": 1,\n  \"trangThai\": \"RESOLVED\"\n}" }, "url": { "raw": "{{baseUrl}}/api/incidents/{{incidentId}}", "host": ["{{baseUrl}}"], "path": ["api","incidents","{{incidentId}}"] } }, "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Update incident returns 200', function () { pm.response.to.have.status(200); });" ] } } ] },
            { "name": "Delete Incident", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/incidents/{{incidentId}}", "host": ["{{baseUrl}}"], "path": ["api","incidents","{{incidentId}}"] } }, "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Delete incident returns 204', function () { pm.response.to.have.status(204); });" ] } } ] },
            { "name": "Resolve Incident", "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/incidents/{{incidentId}}/resolve", "host": ["{{baseUrl}}"], "path": ["api","incidents","{{incidentId}}","resolve"] } }, "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Resolve incident returns 200', function () { pm.response.to.have.status(200); });" ] } } ] }
          ]
        },
        {
          "name": "Guest Entries",
          "item": [
            {
              "name": "Create Guest Entry",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{accessToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"ten\": \"Nguyen Van A\",\n  \"cmnd\": \"0123456789\",\n  \"sdt\": \"0987123456\",\n  \"phongId\": 1,\n  \"loai\": \"IN\",\n  \"ghiChu\": \"Khách thăm\"\n}"
                },
                "url": { "raw": "{{baseUrl}}/api/guest-entries", "host": ["{{baseUrl}}"], "path": ["api","guest-entries"] }
              },
              "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Create guest entry returns 201', function () { pm.response.to.have.status(201); });" ] } } ]
            },
            {
              "name": "List Guest Entries",
              "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/guest-entries", "host": ["{{baseUrl}}"], "path": ["api","guest-entries"] } },
              "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('List guest entries returns 200', function () { pm.response.to.have.status(200); });" ] } } ]
            },
            {
              "name": "Get Guest Entry",
              "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/guest-entries/{{incidentId}}", "host": ["{{baseUrl}}"], "path": ["api","guest-entries","{{incidentId}}"] } },
              "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Get guest entry returns 200', function () { pm.response.to.have.status(200); });" ] } } ]
            },
            {
              "name": "Update Guest Entry",
              "request": {
                "method": "PUT",
                "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" } ],
                "body": { "mode": "raw", "raw": "{\n  \"ten\": \"Nguyen Van A Updated\",\n  \"cmnd\": \"12345678\",\n  \"sdt\": \"0987654321\",\n  \"phongId\": 1\n}" },
                "url": { "raw": "{{baseUrl}}/api/guest-entries/{{incidentId}}", "host": ["{{baseUrl}}"], "path": ["api","guest-entries","{{incidentId}}"] }
              },
              "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Update guest entry returns 200', function () { pm.response.to.have.status(200); });" ] } } ]
            },
            {
              "name": "Delete Guest Entry",
              "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/guest-entries/{{incidentId}}", "host": ["{{baseUrl}}"], "path": ["api","guest-entries","{{incidentId}}"] } },
              "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Delete guest entry returns 204', function () { pm.response.to.have.status(204); });" ] } } ]
            },
            {
              "name": "Approve Guest Entry",
              "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/guest-entries/{{incidentId}}/approve", "host": ["{{baseUrl}}"], "path": ["api","guest-entries","{{incidentId}}","approve"] } },
              "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Approve guest entry returns 200', function () { pm.response.to.have.status(200); });" ] } } ]
            },
            {
              "name": "Reject Guest Entry",
              "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/guest-entries/{{incidentId}}/reject", "host": ["{{baseUrl}}"], "path": ["api","guest-entries","{{incidentId}}","reject"] } },
              "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Reject guest entry returns 200', function () { pm.response.to.have.status(200); });" ] } } ]
            }
          ]
        },
        {
          "name": "Billing",
          "item": [
            { "name": "List Invoices", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/billing/invoices?nam=2026&thang=4", "host": ["{{baseUrl}}"], "path": ["api","billing","invoices"], "query": [ { "key": "nam", "value": "2026" }, { "key": "thang", "value": "4" } ] } }, "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('List invoices returns 200', function () { pm.response.to.have.status(200); });" ] } } ] },
            { "name": "Get Invoice", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/billing/invoices/{{invoiceId}}", "host": ["{{baseUrl}}"], "path": ["api","billing","invoices","{{invoiceId}}"] } }, "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Get invoice returns 200', function () { pm.response.to.have.status(200); });" ] } } ] },
            { "name": "Generate (sync)", "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/billing/generate?ky=2026-04", "host": ["{{baseUrl}}"], "path": ["api","billing","generate"], "query": [ { "key": "ky", "value": "2026-04" } ] } }, "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Generate (sync) returns 200', function () { pm.response.to.have.status(200); });", "try { const arr = pm.response.json(); if (arr && arr.length>0) pm.environment.set('invoiceId', arr[0].id); } catch(e) {}" ] } } ] },
            { "name": "Generate (async)", "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/billing/generate-async?ky=2026-04", "host": ["{{baseUrl}}"], "path": ["api","billing","generate-async"], "query": [ { "key": "ky", "value": "2026-04" } ] } }, "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Generate (async) returns 202', function () { pm.response.to.have.status(202); });" ] } } ] },
            { "name": "Draft", "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"tenantId\": {{tenantId}},\n  \"thang\": 4,\n  \"nam\": 2026\n}" }, "url": { "raw": "{{baseUrl}}/api/billing/draft", "host": ["{{baseUrl}}"], "path": ["api","billing","draft"] } }, "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Draft returns 200', function () { pm.response.to.have.status(200); });", "try { const j = pm.response.json(); if (j && j.id) pm.environment.set('invoiceId', j.id); } catch(e) {}" ] } } ] },
            { "name": "Create QR", "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"hoaDonId\": {{invoiceId}}\n}" }, "url": { "raw": "{{baseUrl}}/api/billing/qr/create", "host": ["{{baseUrl}}"], "path": ["api","billing","qr","create"] } }, "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Create QR returns 200 and contains image and expected amount', function () {", "    pm.response.to.have.status(200);", "    var j = pm.response.json();", "    pm.expect(j).to.have.property('qrImageDataUrl');", "    pm.expect(j.qrImageDataUrl).to.be.a('string');", "    pm.expect(j.qrImageDataUrl).to.match(/^data:image\\//);", "    var invoiceTotal = pm.environment.get('invoiceTotal');", "    if (invoiceTotal) {", "        pm.expect(parseFloat(j.expectedAmount)).to.eql(parseFloat(invoiceTotal));", "    } else {", "        pm.expect(parseFloat(j.expectedAmount)).to.be.above(0);", "    }", "});", "try { var j = pm.response.json(); if (j && j.qrCode) pm.environment.set('qrCode', j.qrCode); if (j && j.id) pm.environment.set('qrLogId', j.id); } catch(e) {}" ] } } ] },
            { "name": "Simulate QR Payment", "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"qrCode\": \"{{qrCode}}\",\n  \"externalTxnId\": \"txn-12345\",\n  \"paidAmount\": 100000\n}" }, "url": { "raw": "{{baseUrl}}/api/billing/payments/qr/simulate", "host": ["{{baseUrl}}"], "path": ["api","billing","payments","qr","simulate"] } }, "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('Simulate QR Payment returns 200', function () { pm.response.to.have.status(200); });" ] } } ] },
