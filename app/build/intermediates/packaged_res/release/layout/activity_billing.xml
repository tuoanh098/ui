<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvBillingHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_panel_tint"
        android:padding="12dp"
        android:text="Luồng billing: tạo kỳ theo tháng -> thanh toán QR -> sau ngày 8 có thể áp phí trễ hạn."
        android:textColor="@color/app_text_muted" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/etYear"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:hint="Năm (VD: 2026)"
            android:inputType="number"/>

        <EditText
            android:id="@+id/etMonth"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:hint="Tháng"
            android:inputType="number"/>

        <Button
            android:id="@+id/btnCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tải dữ liệu" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/generateContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnGenerateSync"
            style="@style/Widget.TroHub.Button.Warning"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Generate Sync" />

        <Button
            android:id="@+id/btnGenerateAsync"
            style="@style/Widget.TroHub.Button.Warning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Generate Async" />
    </LinearLayout>

    <Button
        android:id="@+id/btnToggleQa"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Mở menu test nhỏ (admin)" />

    <LinearLayout
        android:id="@+id/qaContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_panel"
        android:orientation="vertical"
        android:layout_marginBottom="12dp"
        android:padding="12dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/etLateFeePerDay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Phí trễ hạn mỗi ngày (mặc định 100000)"
            android:inputType="number"
            android:text="100000" />

        <Button
            android:id="@+id/btnCreatePrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Create Price điện (4000)" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Đã bỏ 2 nút test reading cũ theo yêu cầu production."
            android:textColor="@color/app_text_muted" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvTitle"
        style="@style/Text.TroHub.Title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Danh Sách Hóa Đơn"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etSearchInvoice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:hint="🔍 Tìm theo người trả, phòng, tòa, mã hóa đơn, trạng thái"
        android:inputType="text" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Không có hóa đơn"
        android:textColor="@color/app_text_muted"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvList"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>

