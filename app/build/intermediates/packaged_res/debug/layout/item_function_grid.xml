<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="0dp"
    android:layout_height="104dp"
    android:background="@drawable/bg_dashboard_card"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingTop="10dp"
    android:paddingEnd="8dp"
    android:paddingBottom="8dp">

    <ImageView
        android:id="@+id/ivFunctionIcon"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/bg_menu_icon"
        android:contentDescription="@null"
        android:padding="7dp"
        android:scaleType="centerInside" />

    <TextView
        android:id="@+id/tvFunctionIcon"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/bg_menu_icon"
        android:gravity="center"
        android:text="•"
        android:textColor="@color/dash_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvFunctionTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:text="Chức năng"
        android:textColor="@color/dash_text_primary"
        android:textSize="13sp"
        android:textStyle="bold" />
</LinearLayout>
