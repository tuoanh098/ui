<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:contentPadding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvContractId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mã Hợp Đồng"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvContractStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trạng thái: "
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvContractPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tiền thuê: 0"
            android:textColor="#388E3C"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvContractRoom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phòng ID: | Người ID: "
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvContractPeriod"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thời hạn: "
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvUtilities"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Giá điện: | Nước: "
            android:layout_marginTop="4dp"
            android:textColor="#555555" />

        <LinearLayout
            android:id="@+id/layoutContractActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="end"
            android:orientation="horizontal"
            android:visibility="gone">

            <Button
                android:id="@+id/btnEditContract"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sửa" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>

