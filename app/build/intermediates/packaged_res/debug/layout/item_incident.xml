<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:contentPadding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvIncidentTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tiêu Đề"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvIncidentStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trạng thái: "
            android:textColor="#D32F2F"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvIncidentRoom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phòng ID: "
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvIncidentReporter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Người báo ID: "
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:id="@+id/layoutIncidentActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="end"
            android:orientation="horizontal"
            android:visibility="gone">

            <Button
                android:id="@+id/btnEditIncident"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sửa" />

            <Button
                android:id="@+id/btnDeleteIncident"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Xóa" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>

