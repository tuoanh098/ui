<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/app_surface"
    app:cardUseCompatPadding="true"
    app:contentPadding="12dp"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvBuildingName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tên Tòa Nhà"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvBuildingAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Địa chỉ: "
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvBuildingRooms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Số phòng: "
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvBuildingManager"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Người quản lý (Chủ trọ ID): "
            android:layout_marginTop="4dp"
            android:textColor="@color/app_text_muted" />

        <LinearLayout
            android:id="@+id/layoutBuildingActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="end"
            android:orientation="horizontal"
            android:visibility="gone">

            <Button
                android:id="@+id/btnEditBuilding"
                style="@style/Widget.TroHub.Button.SmallSecondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sửa" />

            <Button
                android:id="@+id/btnDeleteBuilding"
                style="@style/Widget.TroHub.Button.SmallDanger"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Xóa" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>



