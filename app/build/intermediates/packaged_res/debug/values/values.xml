<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="app_accent">#2563EB</color>
    <color name="app_bg">#F3F6F8</color>
    <color name="app_chip">#E7F0FF</color>
    <color name="app_chip_text">#1D4ED8</color>
    <color name="app_danger">#B42318</color>
    <color name="app_line">#D9E2E7</color>
    <color name="app_on_primary">#FFFFFF</color>
    <color name="app_on_primary_muted">#D0D5DD</color>
    <color name="app_primary">#0F766E</color>
    <color name="app_primary_dark">#0B4F4A</color>
    <color name="app_ripple">#26303030</color>
    <color name="app_success">#15803D</color>
    <color name="app_surface">#FFFFFF</color>
    <color name="app_surface_alt">#EAF3F1</color>
    <color name="app_text">#17212B</color>
    <color name="app_text_muted">#667085</color>
    <color name="app_warning">#D97706</color>
    <color name="dash_bg">#F4F6F8</color>
    <color name="dash_blue">#1565C0</color>
    <color name="dash_divider">#E4E7EC</color>
    <color name="dash_green">#2E7D32</color>
    <color name="dash_orange">#E07A1F</color>
    <color name="dash_primary">#1E3A5F</color>
    <color name="dash_red">#C62828</color>
    <color name="dash_surface">#FFFFFF</color>
    <color name="dash_text_primary">#1F2933</color>
    <color name="dash_text_secondary">#667085</color>
    <style name="Text.TroHub" parent="@style/TextAppearance.AppCompat">
        <item name="android:textColor">@color/app_text</item>
    </style>
    <style name="Text.TroHub.ActionBarTitle" parent="@style/TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/app_on_primary</item>
    </style>
    <style name="Text.TroHub.Body" parent="@style/Text.TroHub">
        <item name="android:textColor">@color/app_text</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="Text.TroHub.Section" parent="@style/Text.TroHub">
        <item name="android:textColor">@color/app_text_muted</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Text.TroHub.Title" parent="@style/Text.TroHub">
        <item name="android:textColor">@color/app_text</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Theme.TroHub" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/app_primary</item>
        <item name="colorPrimaryDark">@color/app_primary_dark</item>
        <item name="colorAccent">@color/app_accent</item>
        <item name="android:windowBackground">@color/app_bg</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:textColorPrimary">@color/app_text</item>
        <item name="android:textColorSecondary">@color/app_text_muted</item>
        <item name="android:buttonStyle">@style/Widget.TroHub.Button</item>
        <item name="buttonStyle">@style/Widget.TroHub.Button</item>
        <item name="android:editTextStyle">@style/Widget.TroHub.EditText</item>
        <item name="editTextStyle">@style/Widget.TroHub.EditText</item>
        <item name="android:spinnerStyle">@style/Widget.TroHub.Spinner</item>
        <item name="actionBarStyle">@style/Widget.TroHub.ActionBar</item>
    </style>
    <style name="Widget.TroHub.ActionBar" parent="@style/Widget.AppCompat.Light.ActionBar.Solid.Inverse">
        <item name="background">@color/app_primary_dark</item>
        <item name="titleTextStyle">@style/Text.TroHub.ActionBarTitle</item>
    </style>
    <style name="Widget.TroHub.Button" parent="@style/Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/app_on_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:minWidth">72dp</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
    </style>
    <style name="Widget.TroHub.Button.Danger" parent="@style/Widget.TroHub.Button">
        <item name="android:background">@drawable/bg_button_danger</item>
        <item name="android:textColor">@color/app_on_primary</item>
    </style>
    <style name="Widget.TroHub.Button.Secondary" parent="@style/Widget.TroHub.Button">
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="android:textColor">@color/app_primary_dark</item>
    </style>
    <style name="Widget.TroHub.Button.SmallDanger" parent="@style/Widget.TroHub.Button.Danger">
        <item name="android:minHeight">36dp</item>
        <item name="android:minWidth">56dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
    </style>
    <style name="Widget.TroHub.Button.SmallSecondary" parent="@style/Widget.TroHub.Button.Secondary">
        <item name="android:minHeight">36dp</item>
        <item name="android:minWidth">56dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
    </style>
    <style name="Widget.TroHub.Button.Warning" parent="@style/Widget.TroHub.Button">
        <item name="android:background">@drawable/bg_button_warning</item>
        <item name="android:textColor">@color/app_on_primary</item>
    </style>
    <style name="Widget.TroHub.EditText" parent="@style/Widget.AppCompat.EditText">
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:textColor">@color/app_text</item>
        <item name="android:textColorHint">@color/app_text_muted</item>
        <item name="android:minHeight">46dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>
    <style name="Widget.TroHub.Spinner" parent="@style/Widget.AppCompat.Spinner">
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:minHeight">46dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
    </style>
</resources>